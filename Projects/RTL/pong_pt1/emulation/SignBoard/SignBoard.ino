bool PongGame()
{
  static bool bInit = true;
  static int8_t ball_x, ball_y, paddle_y;
  static bool ball_x_dir, ball_y_dir, paddle_dir, disable_y = false;

  if (bInit)
  {
    ball_x = 2;
    ball_y = paddle_y = random(32)%16;
    ball_x_dir = ball_y_dir = paddle_dir = true;
    bInit = false;
    //pixels.clear(); // Set all pixel colors to 'off'
    DrawWall(32, 0, 0);

    ScoreBoard(true); // Init
  }

  // Paddle -----------------------------------------------------
  DrawPaddle( paddle_y, 0, 0, 0);
  if (paddle_y<12 && !digitalRead(KEY_UP))    paddle_y++;
  if (paddle_y>0  && !digitalRead(KEY_DOWN))  paddle_y--;
  DrawPaddle( paddle_y, 0, 0, 32);

  // Ball ------------------------------------------------------
  DrawBall(ball_x, ball_y, 0, 0, 0);  // Erase Ball
  if (ball_x_dir) ball_x += 1;
  else
  {
    ball_x -= 1;
    if (ball_x<2)
    {
      ball_x += 1;
      ball_x_dir = true;
    }
  }

  if (!disable_y)
  {
    if (ball_y_dir)
    {
      ball_y += 1;
      if (ball_y>14)
      {
        ball_y = 14;
        ball_y_dir = false;
      }
    }
    else
    {
      ball_y -= 1;
      if (ball_y<0)
      {
        ball_y = 0;
        ball_y_dir = true;
      }
    }
  }
  else
    disable_y = false;

  if (ball_x>28)
  {
    if (ball_y<=(paddle_y+3) && (ball_y+1)>=paddle_y) // Paddle smash Ball
    {
      if (!ScoreBoard(false)) // Cleared?
      {
        Splash(2);  // Yeah!
        Splash(1);
        Splash(0);
        bInit = true;

        return true;  // End of Game
      }

      ball_x -= 1;
      ball_x_dir = false;

      // Special effect!
      if ((ball_y+1)==paddle_y) // Ball smashed upper edge
      {
        ball_y_dir = false;
        disable_y = true;
      }
      else if (ball_y==(paddle_y+3)) // Ball smashed lower edge
      {
        ball_y_dir = true;
        disable_y = true;
      }
      else if (ball_y==(paddle_y+1))
        disable_y = true;
      else
        disable_y = false;
    }
    else   // Paddle missed Ball
    {
      DrawBall(ball_x, ball_y, 0, 32, 0); // Draw Ball
      pixels.show();
      delay(100);
      DrawBall(ball_x, ball_y, 0, 0, 0); // Erase Ball
      pixels.show();
      DrawBall(ball_x+1, ball_y, 0, 32, 0); // Draw Ball
      pixels.show();
      delay(200);

      Splash(1);
      Splash(0);
      
      DrawWall(32, 0, 0);
      ball_x = 2;

      ScoreBoard(true); // Init. Restart Game
    }
  }
  DrawBall(ball_x, ball_y, 0, 32, 0); // Draw Ball

  pixels.show();
  delay(random(10)*10+10);

  return false;
}

void DrawWall( uint8_t R, uint8_t G, uint8_t B)
{
  for (int x=0; x<2; x++)
    for (int y=0; y<16; y++)
      SetPixel(x, y, R, G, B, false);
}

void DrawBall( uint8_t ball_x, uint8_t ball_y, uint8_t R, uint8_t G, uint8_t B)
{
  SetPixel(ball_x,   ball_y,   R, G, B, false);
  SetPixel(ball_x+1, ball_y,   R, G, B, false);
  SetPixel(ball_x,   ball_y+1, R, G, B, false);
  SetPixel(ball_x+1, ball_y+1, R, G, B, false);

  _Score[ball_x]   &= ~((0x01)<<(ball_y));
  _Score[ball_x]   &= ~((0x01)<<(ball_y+1));
  _Score[ball_x+1] &= ~((0x01)<<(ball_y));
  _Score[ball_x+1] &= ~((0x01)<<(ball_y)+1);
}

void DrawPaddle( uint8_t paddle_y, uint8_t R, uint8_t G, uint8_t B)
{
  for (int x=30; x<32; x++)
  {
    SetPixel( x, paddle_y,   R, G, B, false);
    SetPixel( x, paddle_y+1, R, G, B, false);
    SetPixel( x, paddle_y+2, R, G, B, false);
    SetPixel( x, paddle_y+3, R, G, B, false);
  }
}
