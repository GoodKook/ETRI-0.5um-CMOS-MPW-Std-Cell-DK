bool PongGame2()
{
  static bool   bInit = true;
  static int8_t ball_x, ball_y;
  static bool   ball_x_dir, ball_y_dir, disable_y = false;
  static int8_t r_paddle_y, l_paddle_y;

  if (bInit)
  {
    ball_x = 2;
    ball_y = random(15);
    ball_x_dir = ball_y_dir = true;

    l_paddle_y = random(12);
    r_paddle_y = random(12);

    bInit = false;

    ScoreBoard(true); // Init
  }

  // Paddle -----------------------------------------------------
  DrawPaddle_R( r_paddle_y, true);  // Erase
  if (r_paddle_y<12 && !digitalRead(R_KEY_UP))    r_paddle_y++;
  if (r_paddle_y>0  && !digitalRead(R_KEY_DOWN))  r_paddle_y--;
  DrawPaddle_R( r_paddle_y, false);
  DrawPaddle_L( l_paddle_y, true);  // Erase
  if (l_paddle_y<12 && !digitalRead(L_KEY_UP))    l_paddle_y++;
  if (l_paddle_y>0  && !digitalRead(L_KEY_DOWN))  l_paddle_y--;
  DrawPaddle_L( l_paddle_y, false);  // Erase

  // Ball ------------------------------------------------------
  DrawBall(ball_x, ball_y, 0, 0, 0);  // Erase Ball

  // Ball X position------------------------
  if (ball_x_dir) ball_x++;
  else            ball_x--;
  // Ball Y position------------------------
  if (!disable_y)
  {
    if (ball_y_dir)
    {
      ball_y += 1;
      if (ball_y>14)
      {
        ball_y = 14;
        ball_y_dir = false;
      }
    }
    else
    {
      ball_y -= 1;
      if (ball_y<0)
      {
        ball_y = 0;
        ball_y_dir = true;
      }
    }
  }
  else
    disable_y = false;

  if (ball_x>28)  // Ball impact Right Paddle ---------------------------------
  {
    if (ball_y<=(r_paddle_y+3) && (ball_y+1)>=r_paddle_y) // Paddle smash Ball
    {
      if (!ScoreBoard(false)) // Cleared?
      {
        Splash(2);
        SplashWin();  // Yeah!
        Splash(1);
        Splash(0);
        bInit = true;

        return true;  // End of Game
      }

      ball_x -= 1;
      ball_x_dir = false;

      // Special effect!
      if ((ball_y+1)==r_paddle_y) // Ball smashed upper edge
        ball_y_dir = false;
      else if (ball_y==(r_paddle_y+3)) // Ball smashed lower edge
        ball_y_dir = true;
      else if (ball_y==(r_paddle_y+1))
        disable_y = true;
      else
        disable_y = false;
    }
    else   // R-Paddle missed Ball
    {
      DrawBall(ball_x, ball_y, 0, 32, 0); // Draw Ball
      pixels.show();
      delay(100);
      DrawBall(ball_x, ball_y, 0, 0, 0); // Erase Ball
      pixels.show();
      DrawBall(ball_x+1, ball_y, 0, 32, 0); // Draw Ball
      pixels.show();
      delay(200);

      Splash(2);
      SplashScrollDown(2,1);
      Splash(1);
      SplashScrollDown(1,0);
      Splash(0);
      
      ball_x = 2;

      ScoreBoard(true); // Init. Restart Game

      if(!digitalRead(L_KEY_DOWN) && !digitalRead(R_KEY_DOWN))
      {
        bInit = true;
        return true;  // End of Game
      }
    }
  }
  else if (ball_x<2)  // Ball impact Left Paddle ------------------------------
  {
    if (ball_y<=(l_paddle_y+3) && (ball_y+1)>=l_paddle_y) // Paddle smash Ball
    {
      if (!ScoreBoard(false)) // Cleared?
      {
        Splash(2);
        SplashWin();  // Yeah!
        Splash(1);
        Splash(0);
        bInit = true;

        return true;  // End of Game
      }

      ball_x += 1;
      ball_x_dir = true;

      // Special effect!
      if ((ball_y+1)==l_paddle_y) // Ball smashed upper edge
        ball_y_dir = false;
      else if (ball_y==(l_paddle_y+3)) // Ball smashed lower edge
        ball_y_dir = true;
      else if (ball_y==(l_paddle_y+1))
        disable_y = true;
      else
        disable_y = false;
    }
    else   // L-Paddle missed Ball
    {
      DrawBall(ball_x, ball_y, 0, 32, 0); // Draw Ball
      pixels.show();
      delay(100);
      DrawBall(ball_x, ball_y, 0, 0, 0); // Erase Ball
      pixels.show();
      DrawBall(ball_x-1, ball_y, 0, 32, 0); // Draw Ball
      pixels.show();
      delay(200);

      Splash(2);
      SplashScrollDown(2,1);
      Splash(1);
      SplashScrollDown(1,0);
      Splash(0);
      
      ball_x = 28;

      ScoreBoard(true); // Init. Restart Game

      if(!digitalRead(L_KEY_DOWN) && !digitalRead(R_KEY_DOWN))
      {
        bInit = true;
        return true;  // End of Game
      }
    }
  }

  DrawBall(ball_x, ball_y, 0, 32, 0); // Draw Ball

  pixels.show();
  delay(random(SPEED)*SPEED+10);

  return false;
}

//---------------------------------------------------------------------------------
void DrawWall( uint8_t R, uint8_t G, uint8_t B)
{
  for (int x=0; x<2; x++)
    for (int y=0; y<16; y++)
      SetPixel(x, y, R, G, B, false);
}

void DrawBall( uint8_t ball_x, uint8_t ball_y, uint8_t R, uint8_t G, uint8_t B)
{
  SetPixel(ball_x,   ball_y,   R, G, B, false);
  SetPixel(ball_x+1, ball_y,   R, G, B, false);
  SetPixel(ball_x,   ball_y+1, R, G, B, false);
  SetPixel(ball_x+1, ball_y+1, R, G, B, false);

  _Score[ball_x]   &= ~((0x01)<<(ball_y));
  _Score[ball_x]   &= ~((0x01)<<(ball_y+1));
  _Score[ball_x+1] &= ~((0x01)<<(ball_y));
  _Score[ball_x+1] &= ~((0x01)<<(ball_y)+1);
}

void DrawPaddle( uint8_t paddle_y, uint8_t R, uint8_t G, uint8_t B)
{
  for (int x=30; x<32; x++)
  {
    SetPixel( x, paddle_y,   R, G, B, false);
    SetPixel( x, paddle_y+1, R, G, B, false);
    SetPixel( x, paddle_y+2, R, G, B, false);
    SetPixel( x, paddle_y+3, R, G, B, false);
  }
}

void DrawPaddle_R( uint8_t paddle_y, bool bErase)
{
  for (int x=30; x<32; x++)
  {
    if (bErase)
    {
      SetPixel( x, paddle_y,   0, 0, 0, false);
      SetPixel( x, paddle_y+1, 0, 0, 0, false);
      SetPixel( x, paddle_y+2, 0, 0, 0, false);
      SetPixel( x, paddle_y+3, 0, 0, 0, false);
    }
    else
    {
      SetPixel( x, paddle_y,   0, 0, 32, false);
      SetPixel( x, paddle_y+1, 0, 0, 32, false);
      SetPixel( x, paddle_y+2, 0, 0, 32, false);
      SetPixel( x, paddle_y+3, 0, 0, 32, false);
    }
  }
}

void DrawPaddle_L( uint8_t paddle_y, bool bErase)
{
  for (int x=0; x<2; x++)
  {
    if (bErase)
    {
      SetPixel( x, paddle_y,   0, 0, 0, false);
      SetPixel( x, paddle_y+1, 0, 0, 0, false);
      SetPixel( x, paddle_y+2, 0, 0, 0, false);
      SetPixel( x, paddle_y+3, 0, 0, 0, false);
    }
    else
    {
      SetPixel( x, paddle_y,   32, 0, 0, false);
      SetPixel( x, paddle_y+1, 32, 0, 0, false);
      SetPixel( x, paddle_y+2, 32, 0, 0, false);
      SetPixel( x, paddle_y+3, 32, 0, 0, false);
    }
  }
}
