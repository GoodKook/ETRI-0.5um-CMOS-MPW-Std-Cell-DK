#include "Adafruit_NeoPixel.h"
#include <avr/pgmspace.h>

// Which pin on the Arduino is connected to the NeoPixels?
#define L_KEY_DOWN  5
#define L_KEY_UP    6
#define PIXEL_PIN   7 // NeoPixel
#define R_KEY_DOWN  8
#define R_KEY_UP    9

// How many NeoPixels are attached to the Arduino?
#define NUMPIXELS 64 // Popular NeoPixel ring size

// When setting up the NeoPixel library, we tell it how many pixels,
// and which pin to use to send signals. Note that for older NeoPixel
// strips you might need to change the third parameter -- see the
// strandtest example for more information on possible values.
Adafruit_NeoPixel pixels(NUMPIXELS*8, PIXEL_PIN, NEO_GRB + NEO_KHZ800);

#define DELAYVAL 1 // Time (in milliseconds) to pause between pixels
int SPEED = 5;

void setup()
{
  pinMode(L_KEY_UP, INPUT_PULLUP);
  pinMode(L_KEY_DOWN, INPUT_PULLUP);
  pinMode(R_KEY_UP, INPUT_PULLUP);
  pinMode(R_KEY_DOWN, INPUT_PULLUP);

  pixels.begin(); // INITIALIZE NeoPixel strip object (REQUIRED)
}

void loop()
{
  uint8_t Game = 0;

  // Check Key State : All Up
  while(!digitalRead(L_KEY_UP) || !digitalRead(L_KEY_DOWN) ||
        !digitalRead(R_KEY_UP) || !digitalRead(R_KEY_DOWN)) delay(100);

  // Select Game
  SplashRandom();
  //1----------------------------------
  SetPixel(0, 2,  0, 0, 0, false);
  SetPixel(1, 2,  0, 0, 0, false);
  SetPixel(2, 2, 64, 0, 0, false);
  SetPixel(3, 2,  0, 0, 0, false);

  SetPixel(0, 3,  0, 0, 0, false);
  SetPixel(1, 3, 64, 0, 0, false);
  SetPixel(2, 3, 64, 0, 0, false);
  SetPixel(3, 3,  0, 0, 0, false);

  SetPixel(0, 4,  0, 0, 0, false);
  SetPixel(1, 4,  0, 0, 0, false);
  SetPixel(2, 4, 64, 0, 0, false);
  SetPixel(3, 4,  0, 0, 0, false);

  SetPixel(0, 5,  0, 0, 0, false);
  SetPixel(1, 5,  0, 0, 0, false);
  SetPixel(2, 5, 64, 0, 0, false);
  SetPixel(3, 5,  0, 0, 0, false);

  SetPixel(0, 6,  0, 0, 0, false);
  SetPixel(1, 6, 64, 0, 0, false);
  SetPixel(2, 6, 64, 0, 0, false);
  SetPixel(3, 6, 64, 0, 0, false);
  //2----------------------------------
  SetPixel(0, 8, 0, 0, 0, false);
  SetPixel(1, 8, 0, 0,64, false);
  SetPixel(2, 8, 0, 0,64, false);
  SetPixel(3, 8, 0, 0, 0, false);

  SetPixel(0, 9, 0, 0,64, false);
  SetPixel(1, 9, 0, 0, 0, false);
  SetPixel(2, 9, 0, 0, 0, false);
  SetPixel(3, 9, 0, 0,64, false);

  SetPixel(0, 10, 0, 0, 0, false);
  SetPixel(1, 10, 0, 0, 0, false);
  SetPixel(2, 10, 0, 0, 0, false);
  SetPixel(3, 10, 0, 0,64, false);

  SetPixel(0, 11, 0, 0, 0, false);
  SetPixel(1, 11, 0, 0, 0, false);
  SetPixel(2, 11, 0, 0,64, false);
  SetPixel(3, 11, 0, 0, 0, false);

  SetPixel(0, 12, 0, 0, 0, false);
  SetPixel(1, 12, 0, 0,64, false);
  SetPixel(2, 12, 0, 0, 0, false);
  SetPixel(3, 12, 0, 0, 0, false);

  SetPixel(0, 13, 0, 0,64, false);
  SetPixel(1, 13, 0, 0,64, false);
  SetPixel(2, 13, 0, 0,64, false);
  SetPixel(3, 13, 0, 0,64, false);

  pixels.show();
  while(Game==0)
  {
    if (!digitalRead(L_KEY_UP))         Game = 2;
    else if (!digitalRead(L_KEY_DOWN))  Game = 1;
    delay(100);
  } 
  while(!digitalRead(L_KEY_UP) || !digitalRead(L_KEY_DOWN) ||
        !digitalRead(R_KEY_UP) || !digitalRead(R_KEY_DOWN)) delay(100);

  // Select Speed
  SplashRandom();
  //S----------------------------------
  SetPixel(28, 2, 0, 0, 0, false);
  SetPixel(29, 2,64, 0, 0, false);
  SetPixel(30, 2,64, 0, 0, false);
  SetPixel(31, 2,64, 0, 0, false);

  SetPixel(28, 3,64, 0, 0, false);
  SetPixel(29, 3, 0, 0, 0, false);
  SetPixel(30, 3, 0, 0, 0, false);
  SetPixel(31, 3, 0, 0, 0, false);

  SetPixel(28, 4, 0, 0, 0, false);
  SetPixel(29, 4,64, 0, 0, false);
  SetPixel(30, 4,64, 0, 0, false);
  SetPixel(31, 4, 0, 0, 0, false);

  SetPixel(28, 5, 0, 0, 0, false);
  SetPixel(29, 5, 0, 0, 0, false);
  SetPixel(30, 5, 0, 0, 0, false);
  SetPixel(31, 5,64, 0, 0, false);

  SetPixel(28, 6,64, 0, 0, false);
  SetPixel(29, 6,64, 0, 0, false);
  SetPixel(30, 6,64, 0, 0, false);
  SetPixel(31, 6, 0, 0, 0, false);

  //F----------------------------------
  SetPixel(28, 8, 0, 0,64, false);
  SetPixel(29, 8, 0, 0,64, false);
  SetPixel(30, 8, 0, 0,64, false);
  SetPixel(31, 8, 0, 0,64, false);

  SetPixel(28, 9, 0, 0,64, false);
  SetPixel(29, 9, 0, 0, 0, false);
  SetPixel(30, 9, 0, 0, 0, false);
  SetPixel(31, 9, 0, 0, 0, false);

  SetPixel(28,10, 0, 0,64, false);
  SetPixel(29,10, 0, 0,64, false);
  SetPixel(30,10, 0, 0,64, false);
  SetPixel(31,10, 0, 0, 0, false);

  SetPixel(28,11, 0, 0,64, false);
  SetPixel(29,11, 0, 0, 0, false);
  SetPixel(30,11, 0, 0, 0, false);
  SetPixel(31,11, 0, 0, 0, false);

  SetPixel(28,12, 0, 0,64, false);
  SetPixel(29,12, 0, 0, 0, false);
  SetPixel(30,12, 0, 0, 0, false);
  SetPixel(31,12, 0, 0, 0, false);
  pixels.show();

  SPEED = 0;
  while(SPEED==0)
  {
    if (!digitalRead(R_KEY_UP))         SPEED = 5;
    else if (!digitalRead(R_KEY_DOWN))  SPEED = 10;
    delay(100);
  } 
  while(!digitalRead(L_KEY_UP) || !digitalRead(L_KEY_DOWN) ||
        !digitalRead(R_KEY_UP) || !digitalRead(R_KEY_DOWN)) delay(100);

  //SplashWin();
  Splash(2);
  SplashScrollDown(2,1);
  Splash(1);
  SplashScrollDown(1,0);
  Splash(0);

  if (Game==1)
    while(!PongGame1());
  else if (Game==2)
    while(!PongGame2());
  else
    delay(100);
}

